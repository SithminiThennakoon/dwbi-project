      DTS:ExecutableType="Microsoft.ExecuteSQLTask"
      DTS:LocaleID="-1"
      DTS:ObjectName="Truncate Completion Update Staging"
      DTS:ThreadHint="0">
      <DTS:Variables />
      <DTS:ObjectData>
        <SQLTask:SqlTaskData
          SQLTask:Connection="{79B73527-A10A-4B56-9961-BAC059DE5E83}"
          SQLTask:SqlStatementSource="TRUNCATE TABLE stg.StgFactCompletionUpdates;" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
      </DTS:ObjectData>
    </DTS:Executable>
    <DTS:Executable
      DTS:refId="Package\Update Fact Completion Times"
      DTS:CreationName="Microsoft.ExecuteSQLTask"
      DTS:Description="Execute SQL Task"
      DTS:DTSID="{E7B73F43-D783-4107-802D-3780646D1289}"
      DTS:ExecutableType="Microsoft.ExecuteSQLTask"
      DTS:LocaleID="-1"
      DTS:ObjectName="Update Fact Completion Times"
      DTS:ThreadHint="0">
      <DTS:Variables />
      <DTS:ObjectData>
        <SQLTask:SqlTaskData
          SQLTask:Connection="{4F26DBFE-320A-4FA0-B890-D7E9D1B0EE3F}"
          SQLTask:SqlStatementSource="UPDATE f&#xA;SET &#xA;    f.accm_txn_complete_time = u.accm_txn_complete_time,&#xA;    f.txn_process_time_hours = DATEDIFF(HOUR, f.accm_txn_create_time, u.accm_txn_complete_time),&#xA;    f.ModifiedDate = SYSDATETIME()&#xA;FROM dw.Fact311Request f&#xA;JOIN NYC311_Staging.stg.StgFactCompletionUpdates u &#xA;    ON f.AlternateRequestID = u.txn_id&#xA;WHERE u.accm_txn_complete_time &gt;= f.accm_txn_create_time;" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
      </DTS:ObjectData>
    </DTS:Executable>
    <DTS:Executable
      DTS:refId="Package\Validate Missing Txn IDs"
      DTS:CreationName="Microsoft.ExecuteSQLTask"
      DTS:Description="Execute SQL Task"
      DTS:DTSID="{3E62B9F3-B9C4-4470-854F-D5A1E8A3CE25}"
      DTS:ExecutableType="Microsoft.ExecuteSQLTask"
      DTS:LocaleID="-1"
      DTS:ObjectName="Validate Missing Txn IDs"
      DTS:ThreadHint="0">
      <DTS:Variables />
      <DTS:ObjectData>
        <SQLTask:SqlTaskData
          SQLTask:Connection="{4F26DBFE-320A-4FA0-B890-D7E9D1B0EE3F}"
          SQLTask:SqlStatementSource="SELECT u.txn_id&#xA;FROM NYC311_Staging.stg.StgFactCompletionUpdates u&#xA;LEFT JOIN dw.Fact311Request f&#xA;    ON f.AlternateRequestID = u.txn_id&#xA;WHERE f.AlternateRequestID IS NULL;" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
      </DTS:ObjectData>
    </DTS:Executable>
  </DTS:Executables>
