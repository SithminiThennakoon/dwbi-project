    <DTS:Executable
      DTS:refId="Package\Load DimDate"
      DTS:CreationName="Microsoft.ExecuteSQLTask"
      DTS:Description="Execute SQL Task"
      DTS:DTSID="{22151151-EFAC-4A3B-A4AA-E56F15ED5490}"
      DTS:ExecutableType="Microsoft.ExecuteSQLTask"
      DTS:LocaleID="-1"
      DTS:ObjectName="Load DimDate"
      DTS:ThreadHint="0">
      <DTS:Variables />
      <DTS:ObjectData>
        <SQLTask:SqlTaskData
          SQLTask:Connection="{FE62ABA2-58C9-4044-8ADB-8A3BE0C3F98D}"
          SQLTask:SqlStatementSource="INSERT INTO dw.DimDate (DateKey,[Date],[Year],[Quarter],[Month],MonthName,[Day],DayOfWeek,DayName,WeekOfYear)&#xA;SELECT DISTINCT&#xA;    CONVERT(INT, FORMAT(d.dt,'yyyyMMdd')) AS DateKey,&#xA;    CAST(d.dt AS DATE) AS [Date],&#xA;    DATEPART(YEAR, d.dt),&#xA;    DATEPART(QUARTER, d.dt),&#xA;    DATEPART(MONTH, d.dt),&#xA;    DATENAME(MONTH, d.dt),&#xA;    DATEPART(DAY, d.dt),&#xA;    DATEPART(WEEKDAY, d.dt),&#xA;    DATENAME(WEEKDAY, d.dt),&#xA;    DATEPART(WEEK, d.dt)&#xA;FROM (&#xA;    SELECT CAST(created_date AS DATE) dt FROM NYC311_Staging.stg.StgRequestCore WHERE created_date IS NOT NULL&#xA;    UNION&#xA;    SELECT CAST(closed_date AS DATE) dt FROM NYC311_Staging.stg.StgRequestCore WHERE closed_date IS NOT NULL&#xA;    UNION&#xA;    SELECT CAST(due_date AS DATE) dt FROM NYC311_Staging.stg.StgRequestCore WHERE due_date IS NOT NULL&#xA;    UNION&#xA;    SELECT CAST(resolution_action_updated_date AS DATE) dt FROM NYC311_Staging.stg.StgRequestCore WHERE resolution_action_updated_date IS NOT NULL&#xA;) d&#xA;LEFT JOIN dw.DimDate dd ON dd.[Date] = d.dt&#xA;WHERE dd.DateKey IS NULL;" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
      </DTS:ObjectData>
    </DTS:Executable>
