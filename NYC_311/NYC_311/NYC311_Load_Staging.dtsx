  CAST(resolution_description AS NVARCHAR(4000)) AS resolution_description,
  CAST(address_type AS NVARCHAR(50)) AS address_type,
  CAST(location_type AS NVARCHAR(200)) AS location_type,
  CAST(facility_type AS NVARCHAR(50)) AS facility_type,
  CAST(community_board AS NVARCHAR(50)) AS community_board,
  CAST(council_district AS NVARCHAR(20)) AS council_district,
  CAST(police_precinct AS NVARCHAR(50)) AS police_precinct,
  CAST(bbl AS NVARCHAR(30)) AS bbl,
  CAST(park_facility_name AS NVARCHAR(200)) AS park_facility_name,
  CAST(park_borough AS NVARCHAR(100)) AS park_borough,
  CAST(vehicle_type AS NVARCHAR(100)) AS vehicle_type,
  CAST(taxi_company_borough AS NVARCHAR(100)) AS taxi_company_borough,
  CAST(taxi_pick_up_location AS NVARCHAR(100)) AS taxi_pick_up_location,
  CAST(bridge_highway_name AS NVARCHAR(200)) AS bridge_highway_name,
  CAST(bridge_highway_direction AS NVARCHAR(50)) AS bridge_highway_direction,
  CAST(road_ramp AS NVARCHAR(100)) AS road_ramp,
  CAST(bridge_highway_segment AS NVARCHAR(200)) AS bridge_highway_segment
FROM dbo.ServiceRequestCore;</property>
