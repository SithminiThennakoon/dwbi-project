                  UITypeEditor="Microsoft.DataTransformationServices.Controls.ModalMultilineStringEditor, Microsoft.DataTransformationServices.Controls, Version=17.0.0.0, Culture=neutral, PublicKeyToken=89845dcd8080cc91">SELECT
  TRY_CONVERT(BIGINT, unique_key) AS unique_key,
  TRY_CONVERT(DATETIME2, created_date) AS created_date,
  TRY_CONVERT(DATETIME2, closed_date) AS closed_date,
  TRY_CONVERT(DATETIME2, due_date) AS due_date,
  TRY_CONVERT(DATETIME2, resolution_action_updated_date) AS resolution_action_updated_date,
  CAST(agency AS NVARCHAR(20)) AS agency,
